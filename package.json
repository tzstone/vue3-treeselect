{
  "type": "module",
  "name": "@tzstone/vue3-treeselect",
  "version": "1.0.1",
  "description": "A multi-select component with nested options support for Vue 3",
  "keywords": [
    "vue",
    "vue3",
    "treeselect",
    "tree-select",
    "multi-select",
    "nested",
    "dropdown"
  ],
  "author": "tzstone",
  "license": "MIT",
  "homepage": "https://vue-treeselect.js.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzstone/vue3-treeselect.git"
  },
  "bugs": {
    "url": "https://github.com/tzstone/vue3-treeselect/issues"
  },
  "main": "./dist/vue3-treeselect.umd.cjs",
  "module": "./dist/vue3-treeselect.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue3-treeselect.js",
      "require": "./dist/vue3-treeselect.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/vue3-treeselect.css": "./dist/vue3-treeselect.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@tzstone/vue3-treeselect": "^1.0.0",
    "fuzzysearch": "^1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "entities": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "scripts": {
    "dev": "vite --config vite.config.demo.ts",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src --ext .ts,.vue",
    "format": "prettier --write \"src/**/*.{ts,vue,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,json,md}\"",
    "type-check": "vue-tsc --noEmit"
  }
}
